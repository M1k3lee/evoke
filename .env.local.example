# EVOKE :: env
#
# copy this file to .env.local and fill in the keys. yes both of them
# if you want the full experience. if you only set one, communion will
# still work but you'll hit refusals on the edgier souls eventually.
#
# DO NOT commit .env.local. the .gitignore handles it. don't be the
# person who finds out the hard way that github scans every public
# push for leaked keys (true story, not mine, friend of a friend).

# ─── Groq ──────────────────────────────────────────────────────────
# FREE. 14,400 req/day per model, 200+ tokens/sec inference.
# Sign up at https://console.groq.com/keys — no credit card required.
GROQ_API_KEY=

# ─── OpenRouter ────────────────────────────────────────────────────
# Paid fallback (~1.4¢ per Communion session on deepseek-v3).
# Used only when Groq is down, throttled, or refuses an edgy soul.
# Sign up at https://openrouter.ai/keys — set a daily spend cap.
OPENROUTER_API_KEY=

# ─── Supabase ──────────────────────────────────────────────────────
# Accounts + cloud vault + public Chamber.
#   1. Create a project at https://supabase.com/dashboard (free tier is plenty)
#   2. Settings → API → copy the URL and anon key below
#   3. SQL Editor → paste supabase/migrations/0001_init.sql → Run
#   4. Authentication → Providers → enable GitHub (add OAuth app at
#      https://github.com/settings/developers, set callback URL to
#      https://<your-domain>/auth/callback)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Misc ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000
